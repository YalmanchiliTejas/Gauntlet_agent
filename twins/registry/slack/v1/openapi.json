{
  "openapi": "3.0.3",
  "info": { "title": "Slack Web API (twin subset)", "version": "v1" },
  "paths": {
    "/api/chat.postMessage": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/PostInput" } },
            "application/x-www-form-urlencoded": { "schema": { "$ref": "#/components/schemas/PostInput" } }
          }
        },
        "responses": {
          "200": { "content": { "application/json": { "schema": {
            "oneOf": [
              { "$ref": "#/components/schemas/PostResponse" },
              { "$ref": "#/components/schemas/ErrorResponse" }
            ]
          } } } }
        }
      }
    },
    "/api/conversations.history": {
      "get": {
        "parameters": [
          { "name": "channel", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "content": { "application/json": { "schema": {
            "oneOf": [
              { "$ref": "#/components/schemas/HistoryResponse" },
              { "$ref": "#/components/schemas/ErrorResponse" }
            ]
          } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PostInput": {
        "type": "object",
        "comment": "Slack validates args at runtime and returns {ok:false,error} at HTTP 200, not a 4xx — so nothing is hard-required here; the twin enforces channel/text and returns the Slack error envelope.",
        "properties": {
          "channel": { "type": "string" },
          "text": { "type": "string" },
          "username": { "type": "string" },
          "blocks": { "type": "array", "items": { "type": "object" } },
          "attachments": { "type": "array", "items": { "type": "object" } }
        }
      },
      "Message": {
        "type": "object",
        "required": ["type", "text", "ts"],
        "properties": {
          "type": { "type": "string" },
          "text": { "type": "string" },
          "ts": { "type": "string" },
          "username": { "type": "string" }
        }
      },
      "PostResponse": {
        "type": "object",
        "required": ["ok", "ts"],
        "properties": {
          "ok": { "type": "boolean" },
          "channel": { "type": "string" },
          "ts": { "type": "string" },
          "message": { "$ref": "#/components/schemas/Message" }
        }
      },
      "HistoryResponse": {
        "type": "object",
        "required": ["ok", "messages"],
        "properties": {
          "ok": { "type": "boolean" },
          "messages": { "type": "array", "items": { "$ref": "#/components/schemas/Message" } },
          "has_more": { "type": "boolean" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["ok", "error"],
        "properties": {
          "ok": { "type": "boolean" },
          "error": { "type": "string" }
        }
      }
    }
  }
}
