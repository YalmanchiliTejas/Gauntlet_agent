# GitHub App (Contents: read, Checks: write, Pull requests: write)
GITHUB_APP_ID=
# PEM private key. Either inline (use \n for newlines) ...
GITHUB_APP_PRIVATE_KEY=
# ... or point at a file (takes precedence if set):
GITHUB_APP_PRIVATE_KEY_FILE=
GITHUB_WEBHOOK_SECRET=

# Slack (for /slash-command triggers). Leave blank to disable Slack verification.
SLACK_SIGNING_SECRET=

# Sandbox backend: "docker" (local Docker, no AWS) or "microvm" (Lambda MicroVMs).
# Leave blank to auto-pick: docker when MICROVM_S3_BUCKET is empty, else microvm.
GAUNTLET_SANDBOX_BACKEND=

# AWS / MicroVM (only needed when the backend is "microvm")
AWS_REGION=us-east-1
MICROVM_S3_BUCKET=
GEMINI_API_KEY=
GAUNTLET_PLANNER_PROVIDER=
GAUNTLET_PLANNER_MODEL=

# Backend (Supabase Postgres). Leave blank to disable persistence — runs still
# work, they just aren't recorded. Use the Supabase pooled connection string.
# Apply migrations/0001_backend.sql once before first use.
DATABASE_URL=
# SUPABASE_DB_URL is accepted as an alias for DATABASE_URL.
