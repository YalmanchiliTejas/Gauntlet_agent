# GitHub App (Contents: read, Checks: write, Pull requests: write)
GITHUB_APP_ID=
# PEM private key. Either inline (use \n for newlines) ...
GITHUB_APP_PRIVATE_KEY=
# ... or point at a file (takes precedence if set):
GITHUB_APP_PRIVATE_KEY_FILE=
GITHUB_WEBHOOK_SECRET=

# Slack (for /slash-command triggers). Leave blank to disable Slack verification.
SLACK_SIGNING_SECRET=

# AWS / MicroVM
AWS_REGION=us-east-1
MICROVM_S3_BUCKET=
GEMINI_API_KEY=
GAUNTLET_PLANNER_PROVIDER=
GAUNTLET_PLANNER_MODEL=
