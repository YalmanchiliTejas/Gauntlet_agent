[Unit]
Description=Gauntlet sandbox runner (FastAPI)
# Needs the Docker daemon: the docker backend builds/runs customer images.
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
User=gauntlet
WorkingDirectory=/opt/gauntlet
EnvironmentFile=/opt/gauntlet/.env
# Runs on the host (drives host Docker + spawns mitmproxy/twin subprocesses).
ExecStart=/opt/gauntlet/.venv/bin/uvicorn gauntlet.app:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
